# =============================================================
# General temp / crash files
# =============================================================

*.tmp
*.temp
*.bak
*.orig
*.rej
*.log
# core dumps
core
core.*
# Valgrind
vgcore.*
*.pid
*.seed
*.stackdump

# =============================================================
# Secrets & keys — never commit these
# =============================================================

# Generic secret files
.env
.env.*
!.env.example
!.env.template

# Private keys (various formats)
*.pem
*.key
*.p12
*.pfx
*.p8
*.der

# SSH
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*

# GPG / age
*.gpg
secring.*
trustdb.gpg

# Certificates
*.crt
*.cer
*.ca-bundle

# API keys / tokens / credentials files
*credentials*
*token*
*secret*
*.secrets
auth.json
credentials.json
service-account*.json

# AWS
.aws/credentials
*.aws

# Vault / sops
secrets.yaml
secrets.json
secrets.toml
*.dec

# HashiCorp Vault tokens
.vault-token

# kubeconfig (contains cluster credentials)
kubeconfig
kubeconfig.*
*.kubeconfig

# Terraform
*.tfvars

# JWTs / bearer tokens in files
*.jwt

# =============================================================
# Nix
# =============================================================

# Build outputs — symlinks nix build creates in the project root
result
result-*

# =============================================================
# direnv
# =============================================================

# Local direnv cache — machine-specific, rebuilt automatically
.direnv/

# Personal overrides
.envrc.local

